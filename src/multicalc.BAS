5 VAC
10 INPUT "A,base:",$
20 GOSUB 500
30 A=D
35 CSR ,
40 INPUT "+ - * / ↑ S",F$
42 IF F$="S";B=0:GOTO 80
45 CSR ,
50 INPUT "B,base:",$
60 GOSUB 500
70 B=D
80 IF F$="+";R=A+B:GOTO 135
90 IF F$="-";R=A-B:GOTO 135
100 IF F$="*";R=A*B:GOTO 135
110 IF F$="/";R=A/B:GOTO 135
120 IF F$="↑";R=A^B:GOTO 135
130 IF F$="S";R=SQR A
135 IF R>=0;X=INT(R):M$="":GOTO 138
137 X=INT(-R):M$="-"
138 CSR ,
140 N=2:GOSUB 700:PRINT "2[";M$;$;"]"
150 N=8:GOSUB 700:PRINT "8[";M$;$;"]"
160 N=10:GOSUB 700:PRINT "10[";M$;$;"]"
170 N=16:GOSUB 700:PRINT "16[";M$;$;"]"
195 GOTO 5
200 END
500 L=LEN ($):C=0
510 FOR I=1 TO L
520 T$=GETC ($,I)
530 IF T$=",";C=I
540 NEXT I
550 IF L-C=1;T$=GETC ($,C+1):Q=VAL (T$):GOTO 570
560 T$=GETC ($,C+1):U$=GETC ($,C+2):Q=VAL (T$)*10+VAL (U$)
565 P=0:IF GETC ($,1)="-";P=1
570 D=0
580 FOR I=1+P TO C-1
590 T$=GETC ($,I)
600 K=ASCI T$
610 IF K>=48;IF K<=57;V=K-48:GOTO 640
620 IF K>=65;IF K<=70;V=K-55:GOTO 640
630 IF K>=97;IF K<=102;V=K-87:GOTO 640
635 V=0
640 D=D*Q+V
650 NEXT I
655 IF P=1;D=-D
660 RETURN
700 $="":W=X
710 IF W=0;$="0":RETURN
720 Y=W-INT(W/N)*N
730 IF Y<10;S$=CHR(48+Y):GOTO 750
740 S$=CHR(55+Y)
750 $=S$+$
760 W=INT(W/N)
770 IF W>0 THEN 720
780 RETURN
